---
// src/pages/countries.astro
import Base from "../layouts/Base.astro";
import {
	getCountries,
	getContestIndex,
	getContestantDetail,
} from "../lib/data.ts";
import {
	countryFlagUrl,
	broadcasterLogoUrl,
	COUNTRY_BROADCASTER_OVERRIDES,
} from "../lib/utils.ts";

const countries = getCountries();
const index = getContestIndex();

// Build stats per country, plus recent non-cancelled entries for broadcaster lookup
const statsMap: Record<
	string,
	{
		appearances: number;
		wins: number;
		lastYear: number;
		recentEntries: Array<{ year: number; contestantId: number }>;
	}
> = {};
for (const entry of index) {
	for (const c of entry.contestants) {
		if (!statsMap[c.country])
			statsMap[c.country] = {
				appearances: 0,
				wins: 0,
				lastYear: 0,
				recentEntries: [],
			};
		statsMap[c.country].appearances++;
		statsMap[c.country].lastYear = Math.max(
			statsMap[c.country].lastYear,
			entry.year,
		);
		if (!entry.cancelled) {
			statsMap[c.country].recentEntries.push({
				year: entry.year,
				contestantId: c.id,
			});
		}
	}
	if (entry.winner) {
		const code = entry.winner.country;
		if (!statsMap[code])
			statsMap[code] = {
				appearances: 0,
				wins: 0,
				lastYear: 0,
				recentEntries: [],
			};
		statsMap[code].wins++;
	}
}

// Same rotating-broadcaster logic as country/[code].astro
function resolveCurrentBroadcasters(
	code: string,
	recentEntries: Array<{ year: number; contestantId: number }>,
): string[] {
	if (COUNTRY_BROADCASTER_OVERRIDES[code])
		return COUNTRY_BROADCASTER_OVERRIDES[code];
	const entries = [...recentEntries].slice(0, 4);
	const raw: string[] = [];
	for (const e of entries) {
		try {
			const detail = getContestantDetail(e.year, e.contestantId);
			const b = detail.broadcaster;
			if (b) raw.push(b);
		} catch (err) {
			console.error(`[broadcaster] failed ${e.year}/${e.contestantId}:`, err);
		}
	}
	const isRotating =
		raw.length >= 3 && raw[0] !== raw[1] && raw.slice(2).includes(raw[0]);
	const all = isRotating ? [...new Set(raw)] : raw.slice(0, 1);
	const result = all.filter((b) => broadcasterLogoUrl(b) !== null);
	if (result.length === 0 && raw.length > 0) {
		console.error(
			`[broadcaster] raw=${JSON.stringify(raw)} filtered to empty; logoUrls=${raw.map((b) => broadcasterLogoUrl(b))}`,
		);
	}
	return result;
}

const countryList = Object.entries(statsMap)
	.map(([code, stats]) => ({
		code,
		name: countries[code] ?? code,
		appearances: stats.appearances,
		wins: stats.wins,
		lastYear: stats.lastYear,
		broadcasters: resolveCurrentBroadcasters(code, stats.recentEntries),
	}))
	.sort((a, b) => a.name.localeCompare(b.name));
---

<Base title="Countries">
	<div class="container">
		<header class="page-header">
			<h1>All Countries</h1>
			<p class="muted">
				{countryList.length} countries have participated in the Eurovision Song Contest
			</p>
		</header>

		<div class="table-scroll">
			<table class="countries-table">
			<thead>
				<tr>
					<th data-sort="name">Country</th>
					<th data-sort="broadcaster">Broadcaster</th>
					<th class="right" data-sort="wins">Wins</th>
					<th class="right" data-sort="appearances">Appearances</th>
					<th class="right" data-sort="last">Last entry</th>
				</tr>
			</thead>
			<tbody>
				{
					countryList.map((c) => (
						<tr
							data-name={c.name}
							data-broadcaster={c.broadcasters[0] ?? ""}
							data-wins={c.wins}
							data-appearances={c.appearances}
							data-last={c.lastYear}
						>
							<td>
								<img class="flag" src={countryFlagUrl(c.code)} alt="" />
								<a href={`/country/${c.code}/`} class="country-link">
									{c.name}
								</a>
							</td>
							<td class="broadcaster-cell">
								{c.broadcasters.length > 0 ? (
									<div class="broadcaster-logos">
										{c.broadcasters.map((b) => (
											<img
												loading="lazy"
												src={broadcasterLogoUrl(b)!}
												alt={b}
												class="broadcaster-logo"
											/>
										))}
									</div>
								) : (
									<span class="muted">—</span>
								)}
							</td>
							<td class="right mono">
								{c.wins > 0 ? (
									<span class="gold">{c.wins}</span>
								) : (
									<span class="muted">—</span>
								)}
							</td>
							<td class="right mono muted">{c.appearances}</td>
							<td class="right mono muted">{c.lastYear}</td>
						</tr>
					))
				}
			</tbody>
		</table>
		</div>
	</div>
</Base>

<style>
	.page-header {
		padding-block: 3rem 2rem;
		border-bottom: 1px solid var(--c-border);
		margin-bottom: 0;
	}
	.page-header h1 {
		margin-bottom: 0.25rem;
	}

	.countries-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}
	.countries-table th {
		font-family: var(--f-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-muted);
		font-weight: 400;
		padding: 0.75rem 1rem;
		text-align: left;
		border-bottom: 1px solid var(--c-border);
	}
	.countries-table th.right {
		text-align: right;
	}
	.broadcaster-cell {
		white-space: nowrap;
	}
	.broadcaster-logos {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		gap: 0.6rem;
		align-items: center;
	}
	.broadcaster-logo {
		display: block;
		height: 1rem;
		width: auto;
	}
	.countries-table td {
		padding: 0.65rem 1rem;
		border-bottom: 1px solid
			color-mix(in srgb, var(--c-border) 55%, transparent);
		vertical-align: middle;
	}
	.countries-table tr:hover td {
		background: var(--c-surface);
	}
	.countries-table .right {
		text-align: right;
	}

	/* ── Sortable headers ─────────────────────────────────── */
	.countries-table th[data-sort] {
		cursor: pointer;
		user-select: none;
		white-space: nowrap;
	}
	.countries-table th[data-sort]:hover {
		color: var(--c-text);
	}
	.countries-table th.th-sorted {
		color: var(--c-gold);
	}
	.countries-table th.th-sorted::after {
		content: " ↑";
	}
	.countries-table th.th-sorted.th-sorted-desc::after {
		content: " ↓";
	}
</style>

<script>
	const table = document.querySelector(
		".countries-table",
	) as HTMLTableElement | null;
	if (table) {
		const tbody = table.querySelector("tbody") as HTMLTableSectionElement;
		let col = "name",
			dir = "asc";
		const numCols = new Set(["wins", "appearances", "last"]);
		const defaults: Record<string, string> = {
			name: "asc",
			broadcaster: "asc",
			wins: "desc",
			appearances: "desc",
			last: "desc",
		};

		function refresh() {
			table!.querySelectorAll("th[data-sort]").forEach((el) => {
				const th = el as HTMLElement;
				const key = th.dataset.sort;
				th.classList.toggle("th-sorted", key === col);
				th.classList.toggle("th-sorted-desc", key === col && dir === "desc");
			});
		}

		function sort() {
			const rows = [...tbody.querySelectorAll("tr")] as HTMLElement[];
			rows.sort((a, b) => {
				const av = a.dataset[col] ?? "";
				const bv = b.dataset[col] ?? "";
				const raw = numCols.has(col)
					? Number(av) - Number(bv)
					: av.localeCompare(bv);
				return dir === "asc" ? raw : -raw;
			});
			rows.forEach((r) => tbody.appendChild(r));
			refresh();
		}

		table.querySelectorAll("th[data-sort]").forEach((el) =>
			el.addEventListener("click", () => {
				const next = (el as HTMLElement).dataset.sort ?? "";
				if (col === next) dir = dir === "asc" ? "desc" : "asc";
				else {
					col = next;
					dir = defaults[next] ?? "asc";
				}
				sort();
			}),
		);

		refresh(); // show initial indicator without re-sorting
	}
</script>
