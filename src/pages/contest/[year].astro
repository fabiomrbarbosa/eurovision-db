---
// src/pages/contest/[year].astro
import Base from "../../layouts/Base.astro";
import ContestTabs from "../../components/ContestTabs.svelte";
import {
	getYears,
	getResolvedContest,
	getContestIndex,
	getCountryName,
	getCountries,
} from "../../lib/data.ts";
import { countryFlagUrl } from "../../lib/utils.ts";

export async function getStaticPaths() {
	const years = getYears();
	return years.map((year) => ({ params: { year: String(year) } }));
}

const { year: yearParam } = Astro.params;
const year = parseInt(yearParam, 10);

const years = getYears();
const yearIdx = years.indexOf(year);
const prevYear = yearIdx > 0 ? years[yearIdx - 1] : null;
const nextYear = yearIdx < years.length - 1 ? years[yearIdx + 1] : null;

const contestIndex = getContestIndex();
const prevCity = prevYear ? (contestIndex.find((e) => e.year === prevYear)?.city ?? null) : null;
const nextCity = nextYear ? (contestIndex.find((e) => e.year === nextYear)?.city ?? null) : null;

const countries = getCountries();
const contest = getResolvedContest(year);
const hasJuryTele = year > 2015;

// Enrich results with country names
const results = contest.results.map((r) => {
	const finalPerf = r.performances.find((p) => p.round === "final");
	const semiPerf = r.performances.find(
		(p) =>
			p.round === "semifinal1" ||
			p.round === "semifinal2" ||
			p.round === "semifinal",
	);
	return {
		...r,
		countryName: getCountryName(r.country, countries),
		inFinal: finalPerf !== undefined,
		running: finalPerf?.running ?? null,
		finalPlace: finalPerf?.place ?? null,
		finalTotal:
			finalPerf?.scores.find((s) => s.name === "total")?.points ?? null,
		finalJury: finalPerf?.scores.find((s) => s.name === "jury")?.points ?? null,
		finalTele:
			finalPerf?.scores.find((s) => s.name === "public")?.points ?? null,
		semiPlace: semiPerf?.place ?? null,
		qualifiedFromSemi: finalPerf !== undefined || !semiPerf,
		scores: finalPerf?.scores ?? [],
	};
});

// inFinal catches years like 1956 where all performers have place=null (scores were secret)
const finalist = results.filter((r) => r.inFinal);

const hostCountryName = getCountryName(contest.country, countries);
const intendedName = contest.intendedCountry
	? getCountryName(contest.intendedCountry, countries)
	: null;

// Date list from round dates (sorted ascending, deduped)
const roundDates = [
	...new Set(contest.rounds.map((r) => r.date).filter(Boolean)),
].sort();
let contestDates = "";
if (roundDates.length > 0) {
	const parsed = roundDates.map((d) => new Date(d + "T00:00:00Z"));
	const last = parsed[parsed.length - 1];
	const allSameMonth = parsed.every(
		(d) =>
			d.getUTCMonth() === last.getUTCMonth() &&
			d.getUTCFullYear() === last.getUTCFullYear(),
	);
	if (allSameMonth) {
		const days = parsed.map((d) => d.getUTCDate()).join(", ");
		const monthYear = last.toLocaleDateString("en-GB", {
			month: "long",
			year: "numeric",
			timeZone: "UTC",
		});
		contestDates = `${days} ${monthYear}`;
	} else {
		const parts = parsed.map((d, i) => {
			const isLast = i === parsed.length - 1;
			return d.toLocaleDateString("en-GB", {
				day: "numeric",
				month: "long",
				...(isLast ? { year: "numeric" } : {}),
				timeZone: "UTC",
			});
		});
		contestDates = parts.join(", ");
	}
}

// Build semifinal round data for SemifinalsView
const qualifiedToFinalIds = new Set(finalist.map((r) => r.id));
const semiRoundOrder: Record<string, number> = {
	semifinal: 0,
	semifinal1: 1,
	semifinal2: 2,
};
const semiLabelMap: Record<string, string> = {
	semifinal: "Semi-final",
	semifinal1: "Semi-final 1",
	semifinal2: "Semi-final 2",
};
const semiRounds = contest.rounds
	.filter((r) => r.name in semiRoundOrder && r.performances !== null)
	.sort((a, b) => (semiRoundOrder[a.name] ?? 0) - (semiRoundOrder[b.name] ?? 0))
	.map((round) => ({
		label: semiLabelMap[round.name] ?? round.name,
		date: round.date,
		entries: (round.performances ?? [])
			.sort((a, b) => (a.running ?? 0) - (b.running ?? 0))
			.map((perf) => {
				const c = contest.contestantsById[perf.contestantId];
				return {
					id: c.id,
					running: perf.running,
					place: perf.place,
					country: c.country,
					countryName: getCountryName(c.country, countries),
					artist: c.artist,
					song: c.song,
					total: perf.scores.find((s) => s.name === "total")?.points ?? null,
					qualified: qualifiedToFinalIds.has(perf.contestantId),
					scores: perf.scores,
				};
			}),
	}));
---

<Base
	title={`${contest.city} ${year}`}
	description={`Eurovision Song Contest ${year} in ${contest.city}. Full results, scores and voting breakdown.`}
>
	<div class="container">
		<!-- Page header -->
		<header class="contest-header">
			<div class="contest-meta">
				<h1>
					<img class="flag" src={countryFlagUrl(contest.country)} alt="" />
					{contest.city}
					{year}
				</h1>
				<div class="meta-row">
					<span class="meta-item">
						<span class="meta-label">Venue</span>
						{contest.arena} · {hostCountryName}
						{
							intendedName && (
								<>
									on behalf of <strong>{intendedName}</strong>
								</>
							)
						}
					</span>
					{
						contestDates && (
							<span class="meta-item">
								<span class="meta-label">Dates</span>
								{contestDates}
							</span>
						)
					}
					{
						contest.slogan && (
							<span class="meta-item">
								<span class="meta-label">Slogan</span>
								<em>"{contest.slogan}"</em>
							</span>
						)
					}
				</div>
				<div class="meta-row">
					{
						contest.presenters.length > 0 && (
							<span class="meta-item">
								<span class="meta-label">Hosted by</span>
								{contest.presenters.join(" · ")}
							</span>
						)
					}
					{
						contest.broadcasters.length > 0 && (
							<span class="meta-item">
								<span class="meta-label">Broadcaster</span>
								{contest.broadcasters.join(" · ")}
							</span>
						)
					}
				</div>
			</div>

			<img
				src={`/images/logos/${year}.png`}
				alt={`ESC ${year} logo`}
				class="contest-logo"
			/>
		</header>

		<nav class="edition-nav">
			{
				prevYear ? (
					<a href={`/contest/${prevYear}/`} class="edition-nav-link">
						← {prevCity ?? "ESC"} {prevYear}
					</a>
				) : (
					<span />
				)
			}
			{
				nextYear ? (
					<a href={`/contest/${nextYear}/`} class="edition-nav-link">
						{nextCity ?? "ESC"} {nextYear} →
					</a>
				) : (
					<span />
				)
			}
		</nav>

		{
			contest.cancelled ? (
				<section class="cancelled-notice">
					<p class="cancelled-label mono">Contest cancelled</p>
					<p class="cancelled-desc">
						This edition was cancelled and no performances took place.
						{contest.contestants.length > 0 && (
							<>
								{" "}
								{contest.contestants.length} acts had been selected before
								cancellation.
							</>
						)}
					</p>
					{contest.contestants.length > 0 && (
						<div class="table-scroll">
							<table class="results-table">
								<thead>
									<tr>
										<th>Country</th>
										<th>Artist</th>
										<th>Song</th>
									</tr>
								</thead>
								<tbody>
									{contest.contestants.map((c) => (
										<tr>
											<td>
												<img
													class="flag"
													src={countryFlagUrl(c.country)}
													alt=""
												/>
												<a href={`/country/${c.country}/`} class="country-link">
													{getCountryName(c.country, countries)}
												</a>
											</td>
											<td>{c.artist}</td>
											<td class="song-cell">
												<a href={`/contest/${year}/song/${c.id + 1}/`}>
													{c.song}
												</a>
											</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					)}
				</section>
			) : (
				<>
					<section class="results-section">
						<ContestTabs
							client:load
							semiRounds={semiRounds}
							finalists={finalist}
							countries={countries}
							hasJuryTele={hasJuryTele}
							year={year}
						/>
					</section>
				</>
			)
		}
	</div>
</Base>

<style>
	/* ── Contest header ─────────────────────────────────────────── */
	.contest-header {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		padding-block: 3rem 2.5rem;
		border-bottom: 1px solid var(--c-border);
		margin-bottom: 1.5rem;
	}

	.contest-logo {
		width: auto;
		height: auto;
		max-height: 175px;
		max-width: 240px;
		flex-shrink: 0;
		background-color: white;
	}

	@media (min-width: 640px) {
		.contest-header {
			flex-direction: row;
		}
	}

	@media (max-width: 639px) {
		.contest-meta {
			order: 2;
		}
		.contest-logo {
			order: 1;
		}
	}

	.eyebrow {
		font-size: 0.75rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		margin-bottom: 0.35rem;
	}
	.contest-header h1 {
		margin-bottom: 2rem;
	}
	.meta-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin-top: 1rem;
	}
	.meta-item {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		font-size: 0.875rem;
	}
	.meta-label {
		font-family: var(--f-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-muted);
	}

	/* ── Edition navigation ─────────────────────────────────────── */
	.edition-nav {
		display: flex;
		justify-content: space-between;
		margin-bottom: 3rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--c-border);
	}
	.edition-nav-link {
		font-family: var(--f-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-muted);
		text-decoration: none;
		transition: color 0.12s;
	}
	.edition-nav-link:hover {
		color: var(--c-link);
	}

	/* ── Results section wrapper ────────────────────────────────── */
	.results-section {
		margin-bottom: 4rem;
	}

	/* ── Cancelled notice ──────────────────────────────────────── */
	.cancelled-notice {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	.cancelled-label {
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--c-muted);
	}
	.cancelled-desc {
		font-size: 0.95rem;
		color: var(--c-muted);
		max-width: 60ch;
		margin-bottom: 1rem;
	}
</style>
