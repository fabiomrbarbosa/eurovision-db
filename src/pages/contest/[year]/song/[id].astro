---
// src/pages/contest/[year]/song/[id].astro
import Base from "../../../../layouts/Base.astro";
import LyricsTabs from "../../../../components/LyricsTabs.svelte";
import VoteTabs from "../../../../components/VoteTabs.svelte";
import VideoPlayer from "../../../../components/VideoPlayer.svelte";
import {
	getYears,
	getContest,
	getContestantDetail,
	getCountryName,
	getCountries,
	getCountryHistory,
} from "../../../../lib/data.ts";
import { countryFlagUrl, ordinal } from "../../../../lib/utils.ts";
import { existsSync } from "fs";
import { join } from "path";

export function getStaticPaths() {
	const years = getYears();
	const paths: { params: { year: string; id: string } }[] = [];
	for (const year of years) {
		const contest = getContest(year);
		for (const c of contest.contestants) {
			const filePath = join(
				process.cwd(),
				"src/data/contestants",
				String(year),
				`${c.id}.json`,
			);
			if (existsSync(filePath)) {
				paths.push({ params: { year: String(year), id: String(c.id + 1) } });
			}
		}
	}
	return paths;
}

const { year: yearParam, id: idParam } = Astro.params;
const year = parseInt(yearParam, 10);
const id = parseInt(idParam, 10) - 1;

const countries = getCountries();
const detail = getContestantDetail(year, id);
const contest = getContest(year);

const countryName = getCountryName(detail.country, countries);

// Gather performances across all rounds
const roundLabelMap: Record<string, string> = {
	final: "Grand Final",
	semifinal: "Semi-final",
	semifinal1: "Semi-final 1",
	semifinal2: "Semi-final 2",
};
const roundOrder: Record<string, number> = {
	semifinal: 0,
	semifinal1: 1,
	semifinal2: 2,
	final: 3,
};

const performances = contest.rounds
	.map((round) => {
		const perf = round.performances?.find((p) => p.contestantId === id);
		if (!perf) return null;
		const total = perf.scores.find((s) => s.name === "total")?.points ?? null;
		const jury = perf.scores.find((s) => s.name === "jury")?.points ?? null;
		const tele = perf.scores.find((s) => s.name === "public")?.points ?? null;
		const totalVotes = perf.scores.find((s) => s.name === "total")?.votes ?? {};
		const juryVotes = perf.scores.find((s) => s.name === "jury")?.votes ?? {};
		const teleVotes = perf.scores.find((s) => s.name === "public")?.votes ?? {};
		return {
			round: round.name,
			label: roundLabelMap[round.name] ?? round.name,
			running: perf.running ?? null,
			place: perf.place,
			total,
			jury,
			tele,
			totalVotes,
			juryVotes,
			teleVotes,
		};
	})
	.filter(Boolean)
	.sort(
		(a, b) => (roundOrder[a!.round] ?? 0) - (roundOrder[b!.round] ?? 0),
	) as {
	round: string;
	label: string;
	running: number | null;
	place: number | null;
	total: number | null;
	jury: number | null;
	tele: number | null;
	totalVotes: Record<string, number>;
	juryVotes: Record<string, number>;
	teleVotes: Record<string, number>;
	disqualified?: boolean;
}[];

// Qualified from a semi but DQ'd from the final: contestant has a semi performance
// AND appears in that round's disqualifieds (i.e. they earned their spot but were pulled).
const disqualifiedFromFinal =
	!performances.some((p) => p.round === "final") &&
	contest.rounds.some(
		(r) =>
			(r.disqualifieds ?? []).includes(id) &&
			r.performances?.some((p) => p.contestantId === id),
	);

if (disqualifiedFromFinal) {
	performances.push({
		round: "final",
		label: "Grand Final",
		running: null,
		place: null,
		total: null,
		jury: null,
		tele: null,
		totalVotes: {},
		juryVotes: {},
		teleVotes: {},
		disqualified: true,
	});
}

// Per-round voter rows: sorted by total desc, only voters who gave points
const votesByRound = performances
	.filter((p) => Object.keys(p.totalVotes).length > 0)
	.map((p) => ({
		round: p.round,
		label: p.label,
		voters: Object.entries(p.totalVotes)
			.map(([code, pts]) => ({
				code,
				name: code === "WLD" ? "Rest of the World" : (countries[code] ?? code),
				total: pts,
				jury: p.juryVotes[code] ?? null,
				tele: p.teleVotes[code] ?? null,
			}))
			.sort((a, b) => b.total - a.total),
	}));

// Maps round name → tab index in votesByRound (used by result pills)
const roundToVoteIdx: Record<string, number> = Object.fromEntries(
	votesByRound.map((r, i) => [r.round, i]),
);

// API occasionally returns a bare string instead of string[] for single-value fields
const toArr = (v: string | string[] | null | undefined): string[] =>
	!v ? [] : Array.isArray(v) ? v : [v];

const originalLyrics = detail.lyrics.find((l) => l.type === 0);
const languages = originalLyrics?.languages ?? [];

// Credits: combine writers/composers/lyricists, dedup
const allWriters = [
	...new Set([
		...toArr(detail.writers),
		...toArr(detail.composers),
		...toArr(detail.lyricists),
	]),
];
const hasJuryTele = year > 2015;

const videoUrls = detail.videoUrls ?? [];

// Country song navigation: prev/next year this country appeared
const countryHistory = getCountryHistory(detail.country);
const histIdx = countryHistory.findIndex(
	(a) => a.year === year && a.contestantId === id,
);
const prevEntry = histIdx > 0 ? countryHistory[histIdx - 1] : null;
const nextEntry =
	histIdx < countryHistory.length - 1 ? countryHistory[histIdx + 1] : null;

const title = `${detail.artist} - ${detail.song} (${countryName} ${year})`;
const description = `${detail.artist} represented ${countryName} at Eurovision ${year} with "${detail.song}".`;
---

<Base {title} {description}>
	<div class="container">
		<!-- Hero -->
		<header class="contestant-header">
			<div class="contestant-meta">
				<div class="contestant-eyebrow">
					<a href={`/country/${detail.country}/`} class="country-link">
						<img class="flag" src={countryFlagUrl(detail.country)} alt="" />{
							countryName
						}
					</a>
					<span class="muted">·</span>
					<a href={`/contest/${year}/`} class="edition-link muted"
						>Eurovision {year}</a
					>
				</div>
				<h1>{detail.artist}</h1>
				<p class="song-title">{detail.song}</p>
			</div>

			<!-- Performance results -->
			{
				performances.length > 0 && (
					<div class="results-row">
						{performances.map((p) => (
							<div
								class="result-pill"
								data-vote-idx={p.disqualified ? undefined : roundToVoteIdx[p.round]}
							>
								<span class="result-label">{p.label}</span>
								{p.disqualified ? (
									<span class="result-place mono result-dq">Disqualified</span>
								) : (
									<>
										{p.running != null && (
											<span class="result-label">Draw #{p.running}</span>
										)}
										<span
											class={`result-place mono${p.place === 1 && p.round === "final" ? " gold" : ""}`}
										>
											{p.place != null ? ordinal(p.place) : "—"}
										</span>
										{p.total != null && (
											<span
												class={`result-pts mono${p.place === 1 && p.round === "final" ? " gold" : ""}`}
											>
												{p.total} pts
											</span>
										)}
										{hasJuryTele && p.jury != null && (
											<span class="result-split mono muted">
												J {p.jury} · T {p.tele}
											</span>
										)}
									</>
								)}
							</div>
						))}
					</div>
				)
			}
		</header>

		<nav class="song-nav">
			{
				prevEntry ? (
					<a
						href={`/contest/${prevEntry.year}/song/${prevEntry.contestantId + 1}/`}
						class="song-nav-link"
					>
						← {countryName} {prevEntry.year}
					</a>
				) : (
					<span />
				)
			}
			{
				nextEntry ? (
					<a
						href={`/contest/${nextEntry.year}/song/${nextEntry.contestantId + 1}/`}
						class="song-nav-link"
					>
						{countryName} {nextEntry.year} →
					</a>
				) : (
					<span />
				)
			}
		</nav>

		<div class="contestant-body">
			<!-- Left column: video + lyrics -->
			<div class="col-main">
				{
					videoUrls.length > 0 && (
						<section class="section-video">
							<VideoPlayer
								{videoUrls}
								title={`${detail.artist} — ${detail.song}`}
								client:load
							/>
						</section>
					)
				}

				{
					detail.lyrics.length > 0 && (
						<section class="section-lyrics">
							<h2 class="section-heading">Lyrics</h2>
							<LyricsTabs lyrics={detail.lyrics} client:load />
						</section>
					)
				}
			</div>

			<!-- Right column: metadata + credits + broadcast -->
			<aside class="col-side">
				<!-- Song metadata -->
				<section class="side-section">
					<h2 class="section-heading">Song</h2>
					<dl class="meta-list">
						{
							languages.length > 0 && (
								<>
									<dt>Language</dt>
									<dd>
										{languages
											.map((l) => l.charAt(0).toUpperCase() + l.slice(1))
											.join(", ")}
									</dd>
								</>
							)
						}
						{
							detail.bpm != null && (
								<>
									<dt>BPM</dt>
									<dd class="mono">{detail.bpm}</dd>
								</>
							)
						}
						{
							detail.tone && (
								<>
									<dt>Key</dt>
									<dd class="mono">{detail.tone}</dd>
								</>
							)
						}
						{
							detail.artistPeople && detail.artistPeople.length > 0 && (
								<>
									<dt>
										{detail.artistPeople.length === 1 ? "Artist name" : "Members"}
									</dt>
									<dd>{detail.artistPeople.join(", ")}</dd>
								</>
							)
						}
					</dl>
				</section>

				<!-- Credits -->
				{
					allWriters.length > 0 ||
					detail.stageDirector ||
					toArr(detail.backings).length > 0 ||
					toArr(detail.dancers).length > 0 ||
					detail.conductor ? (
						<section class="side-section">
							<h2 class="section-heading">Credits</h2>
							<dl class="meta-list">
								{allWriters.length > 0 && (
									<>
										<dt>Written by</dt>
										<dd>{allWriters.join(", ")}</dd>
									</>
								)}
								{detail.stageDirector && (
									<>
										<dt>Stage direction</dt>
										<dd>{detail.stageDirector}</dd>
									</>
								)}
								{toArr(detail.backings).length > 0 && (
									<>
										<dt>Backing vocals</dt>
										<dd>{toArr(detail.backings).join(", ")}</dd>
									</>
								)}
								{toArr(detail.dancers).length > 0 && (
									<>
										<dt>Dancers</dt>
										<dd>{toArr(detail.dancers).join(", ")}</dd>
									</>
								)}
								{detail.conductor && (
									<>
										<dt>Conductor</dt>
										<dd>{detail.conductor}</dd>
									</>
								)}
							</dl>
						</section>
					) : null
				}

				<!-- Broadcasting -->
				{
					(detail.broadcaster ||
						detail.spokesperson ||
						toArr(detail.commentators).length > 0 ||
						toArr(detail.jury).length > 0) && (
						<section class="side-section">
							<h2 class="section-heading">Broadcast</h2>
							<dl class="meta-list">
								{detail.broadcaster && (
									<>
										<dt>Broadcaster</dt>
										<dd>{detail.broadcaster}</dd>
									</>
								)}
								{detail.spokesperson && (
									<>
										<dt>Spokesperson</dt>
										<dd>{detail.spokesperson}</dd>
									</>
								)}
								{toArr(detail.commentators).length > 0 && (
									<>
										<dt>Commentators</dt>
										<dd>{toArr(detail.commentators).join(", ")}</dd>
									</>
								)}
								{toArr(detail.jury).length > 0 && (
									<>
										<dt>National jury</dt>
										<dd>{toArr(detail.jury).join(", ")}</dd>
									</>
								)}
							</dl>
						</section>
					)
				}
			</aside>
		</div>

		{
			votesByRound.length > 0 && (
				<section id="votes-section" class="votes-section">
					<h2 class="section-heading">Voting breakdown</h2>
					<VoteTabs rounds={votesByRound} {hasJuryTele} client:load />
				</section>
			)
		}
	</div>

	<style>
		/* ── Song navigation ──────────────────────────────────────── */
		.song-nav {
			display: flex;
			justify-content: space-between;
			margin-bottom: 3rem;
			padding-bottom: 1.5rem;
			border-bottom: 1px solid var(--c-border);
		}
		.song-nav-link {
			font-family: var(--f-mono);
			font-size: 0.75rem;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--c-muted);
			text-decoration: none;
			transition: color 0.12s;
		}
		.song-nav-link:hover {
			color: var(--c-link);
		}

		/* ── Header ───────────────────────────────────────────────── */
		.contestant-header {
			display: flex;
			flex-direction: column;
			justify-content: space-between;
			gap: 1.5rem;
			padding-top: 2rem;
			padding-bottom: 2rem;
			margin-bottom: 1.5rem;
			border-bottom: 1px solid var(--c-border);
		}
		@media (min-width: 600px) {
			.contestant-header {
				flex-direction: row;
			}
		}
		.contestant-eyebrow {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-bottom: 1rem;
			font-size: 0.9rem;
		}
		.country-link {
			display: inline-flex;
			align-items: center;
			color: var(--c-text);
			font-weight: 500;
			text-decoration: underline;
			text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
		}
		.country-link:hover {
			color: var(--c-link);
			text-decoration-color: currentColor;
		}
		.edition-link {
			text-decoration: underline;
			text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
		}
		.edition-link:hover {
			color: var(--c-link);
			text-decoration-color: currentColor;
		}

		.contestant-header h1 {
			font-size: clamp(2rem, 5vw, 3rem);
			line-height: 1;
		}
		.song-title {
			font-size: clamp(1.4rem, 3vw, 2rem);
			font-weight: 700;
			color: var(--c-muted);
		}

		/* ── Results pills ────────────────────────────────────────── */
		.results-row {
			display: flex;
			flex-wrap: nowrap;
			gap: 0.75rem;
		}
		.result-pill {
			display: flex;
			flex-direction: column;
			gap: 0.2rem;
			padding: 0.75rem 1rem;
			background: rgba(0, 0, 0, 0.5);
			border: 1px solid var(--c-border);
			border-radius: 4px;
			min-width: 9rem;
		}
		.result-label {
			font-family: var(--f-mono);
			font-size: 0.68rem;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--c-muted);
		}
		.result-place {
			font-size: 1.4rem;
			font-weight: 600;
			line-height: 1.2;
			margin-top: 0.5rem;
		}
		.result-dq {
			font-size: 0.85rem;
			color: var(--c-magenta);
		}
		.result-pts {
			font-size: 0.8rem;
		}
		.result-split {
			font-size: 0.75rem;
		}
		.result-pill[data-vote-idx] {
			cursor: pointer;
		}
		.result-pill[data-vote-idx]:hover {
			border-color: var(--c-gold-dim);
			background: rgba(0, 0, 0, 0.7);
		}

		/* ── Body layout ──────────────────────────────────────────── */
		.contestant-body {
			display: grid;
			grid-template-columns: 1fr;
			gap: 3rem;
		}
		.col-main {
			min-width: 0;
		}
		@media (min-width: 900px) {
			.contestant-body {
				grid-template-columns: 1fr 22rem;
				align-items: start;
			}
		}

		/* ── Video ────────────────────────────────────────────────── */
		.section-video {
			margin-bottom: 2.5rem;
		}

		/* ── Sections ─────────────────────────────────────────────── */

		.section-heading {
			font-family: var(--f-mono);
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.1em;
			color: var(--c-text);
			margin-bottom: 1rem;
			padding-bottom: 0.5rem;
			border-bottom: 1px solid var(--c-border);
		}

		/* ── Lyrics ───────────────────────────────────────────────── */
		.lyric-block {
			margin-bottom: 2rem;
		}
		.lyric-meta {
			display: flex;
			align-items: baseline;
			gap: 0.75rem;
			margin-bottom: 1rem;
		}
		.lyric-type {
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: var(--c-gold);
		}
		.lyric-langs {
			font-size: 0.8rem;
		}
		.lyric-stanza {
			white-space: pre-line;
			line-height: 1.75;
			margin-bottom: 1.25rem;
			font-size: 0.9rem;
			color: var(--c-text);
		}

		/* ── Sidebar sections ─────────────────────────────────────── */
		.side-section {
			margin-bottom: 2rem;
		}

		/* ── Votes section ───────────────────────────────────────── */
		.votes-section {
			padding-top: 3rem;
			padding-bottom: 4rem;
		}
		.votes-section .section-heading {
			margin-bottom: 1.5rem;
		}

		/* ── Meta list (dt/dd pairs) ──────────────────────────────── */
		.meta-list {
			display: grid;
			grid-template-columns: auto 1fr;
			gap: 0.4rem 1rem;
			font-size: 0.875rem;
		}
		.meta-list dt {
			font-family: var(--f-mono);
			font-size: 0.72rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			color: var(--c-muted);
			padding-top: 0.1em;
			white-space: nowrap;
		}
		.meta-list dd {
			color: var(--c-text);
			line-height: 1.5;
		}
	</style>

	<script>
		document.querySelectorAll<HTMLElement>("[data-vote-idx]").forEach((el) => {
			el.addEventListener("click", () => {
				const idx = parseInt(el.dataset.voteIdx!);
				const section = document.getElementById("votes-section");
				if (section) {
					const top = section.getBoundingClientRect().top + window.scrollY - 90;
					window.scrollTo({ top, behavior: "smooth" });
				}
				window.dispatchEvent(new CustomEvent("vote-round", { detail: idx }));
			});
		});
	</script>
</Base>
