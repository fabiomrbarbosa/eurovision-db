---
// src/pages/country/[code].astro
import Base from "../../layouts/Base.astro";
import {
	getCountries,
	getCountryHistory,
	getContestIndex,
	getContestantDetail,
} from "../../lib/data.ts";
import {
	countryFlagUrl,
	ordinal,
	expandBroadcaster,
	broadcasterLogoUrl,
	broadcasterLogoSquare,
} from "../../lib/utils.ts";

export async function getStaticPaths() {
	const index = getContestIndex();
	const codes = new Set<string>();
	for (const e of index) {
		for (const c of e.contestants) codes.add(c.country);
	}
	return Array.from(codes).map((code) => ({ params: { code } }));
}

const { code } = Astro.params;
const countries = getCountries();
const countryName = countries[code] ?? code;
const history = getCountryHistory(code);

const wins = history.filter((h) => h.finalPlace === 1).length;
const appearances = history.length;
const bestPlace = Math.min(...history.map((h) => h.finalPlace ?? Infinity));

const recentEntries = [...history]
	.reverse()
	.filter((h) => !h.cancelled)
	.slice(0, 4);
const recentBroadcasters: string[] = [];
for (const entry of recentEntries) {
	try {
		const b = getContestantDetail(entry.year, entry.contestantId).broadcaster;
		if (b) recentBroadcasters.push(b);
	} catch {
		// detail file unavailable
	}
}
// Show multiple broadcasters only when the pattern is truly rotating:
// the most recent broadcaster reappears at index 2+ (non-consecutive),
// as Belgium does (RTBF→VRT→RTBF→VRT). A permanent switch (NewBC→NewBC→OldBC)
// would not satisfy this and correctly shows only the new broadcaster.
const isRotating =
	recentBroadcasters.length >= 3 &&
	recentBroadcasters[0] !== recentBroadcasters[1] &&
	recentBroadcasters.slice(2).includes(recentBroadcasters[0]);
const allBroadcasters = isRotating
	? [...new Set(recentBroadcasters)]
	: recentBroadcasters.slice(0, 1);
const currentBroadcasters = allBroadcasters.filter((b) => broadcasterLogoUrl(b) !== null);

function computeRanges(years: number[]): string[] {
	if (years.length === 0) return [];
	const sorted = [...new Set(years)].sort((a, b) => a - b);
	const segs: Array<[number, number]> = [];
	let s = sorted[0],
		p = sorted[0];
	for (let i = 1; i < sorted.length; i++) {
		if (sorted[i] === p + 1) p = sorted[i];
		else {
			segs.push([s, p]);
			s = sorted[i];
			p = sorted[i];
		}
	}
	segs.push([s, p]);
	return segs.map(([a, b]) => (a === b ? `${a}` : `${a}–${b}`));
}

function splitForDisplay(ranges: string[]): [string, string] {
	if (ranges.length === 0) return ["", ""];
	if (ranges.length === 1) {
		const parts = ranges[0].split("–");
		if (parts.length === 1) return [parts[0], ""];
		return [parts[0] + "–", parts[1]];
	}
	const total =
		ranges.reduce((sum, r) => sum + r.length, 0) + (ranges.length - 1) * 2;
	const half = total / 2;
	let cum = 0,
		best = 1,
		bestDiff = Infinity;
	for (let i = 1; i < ranges.length; i++) {
		cum += ranges[i - 1].length + (i > 1 ? 2 : 0);
		const diff = Math.abs(cum - half);
		if (diff < bestDiff) {
			bestDiff = diff;
			best = i;
		}
	}
	return [
		ranges.slice(0, best).join(", ") + ",",
		ranges.slice(best).join(", "),
	];
}

const ranges = computeRanges(history.map((h) => h.year));
// Count individual 4-digit year numbers visible: "1956–1965" → 2, "1956" → 1
const yearNumberCount = ranges.reduce((sum, r) => sum + r.split("–").length, 0);
const oneLiner = yearNumberCount <= 5;
const [yearsLine1, yearsLine2] = splitForDisplay(ranges);
---

<Base
	title={countryName}
	description={`${countryName} at the Eurovision Song Contest — ${appearances} appearances${wins > 0 ? `, ${wins} win${wins !== 1 ? "s" : ""}` : bestPlace !== Infinity ? `, best place ${ordinal(bestPlace)}` : ""}.`}
>
	<div class="container">
		<header class="country-header">
			<h1>
				<img class="flag" src={countryFlagUrl(code)} alt="" />{countryName}
			</h1>
			<div class="stats-row">
				{
					currentBroadcasters.length > 0 && (
						<div class="stat">
							<div class="broadcaster-logos">
								{currentBroadcasters.map((b) =>
									broadcasterLogoUrl(b) ? (
										<img
											src={broadcasterLogoUrl(b)!}
											alt=""
											class="broadcaster-logo"
										/>
									) : (
										<span class="stat-value">{expandBroadcaster(b)}</span>
									),
								)}
							</div>
							<span class="stat-label muted">
								{currentBroadcasters.length > 1
									? "Broadcasters"
									: "Broadcaster"}
							</span>
						</div>
					)
				}
				{
					wins > 0 ? (
						<div class="stat">
							<span class="stat-value mono gold">{wins}</span>
							<span class="stat-label muted">Win{wins !== 1 ? "s" : ""}</span>
						</div>
					) : (
						bestPlace !== Infinity && (
							<div class="stat">
								<span class="stat-value mono">{ordinal(bestPlace)}</span>
								<span class="stat-label muted">Best place</span>
							</div>
						)
					)
				}
				<div class="stat">
					<span class="stat-value mono">{appearances}</span>
					<span class="stat-label muted">Appearances</span>
				</div>
				{
					yearsLine1 && (
						<div class="stat">
							<span
								class:list={["stat-value mono", !oneLiner && "years-value"]}
							>
								{oneLiner ? (
									ranges.join(", ")
								) : (
									<>
										{yearsLine1}
										{yearsLine2 && (
											<>
												<br />
												{yearsLine2}
											</>
										)}
									</>
								)}
							</span>
							<span class="stat-label muted">Active years</span>
						</div>
					)
				}
			</div>
		</header>

		<section class="history-section">
			<h2>Contest history</h2>
			<div class="table-scroll">
				<table class="history-table">
					<thead>
						<tr>
							<th data-sort="year">Year</th>
							<th data-sort="artist">Artist</th>
							<th data-sort="song">Song</th>
							<th class="right" data-sort="place">Final</th>
							<th class="right" data-sort="points">Points</th>
						</tr>
					</thead>
					<tbody>
						{
							history
								.slice()
								.reverse()
								.map((h) => (
									<tr
										class:list={[h.finalPlace === 1 && "row--winner"]}
										data-year={h.year}
										data-artist={h.artist}
										data-song={h.song}
										data-place={h.finalPlace ?? ""}
										data-points={h.finalPoints ?? ""}
									>
										<td>
											<a href={`/contest/${h.year}/`} class="year-link mono">
												{h.year}
											</a>
										</td>
										<td>{h.artist}</td>
										<td class="song-cell">
											<a
												href={`/contest/${h.year}/song/${h.contestantId + 1}/`}
											>
												{h.song}
											</a>
										</td>
										<td class="right mono">
											{h.finalPlace === 1 ? (
												<span class="gold">🏆 1st</span>
											) : h.finalPlace !== null ? (
												<span class="muted">{ordinal(h.finalPlace)}</span>
											) : h.cancelled ? (
												<span class="badge badge--magenta">Cancelled</span>
											) : h.disqualified ? (
												<span class="badge badge--magenta">DQ</span>
											) : h.participatedInFinal ? (
												<span class="muted">—</span>
											) : (
												<span class="badge badge--magenta">NQ</span>
											)}
										</td>
										<td class="right mono">
											{h.finalPoints !== null ? (
												<span class:list={[h.finalPlace === 1 && "gold"]}>
													{h.finalPoints}
												</span>
											) : (
												<span class="muted">—</span>
											)}
										</td>
									</tr>
								))
						}
					</tbody>
				</table>
			</div>
		</section>
	</div>
</Base>

<style>
	/* ── Country header ─────────────────────────────────────────── */
	.country-header {
		padding-block: 3rem 2.5rem;
		border-bottom: 1px solid var(--c-border);
		margin-bottom: 3rem;
	}
	.eyebrow {
		font-size: 0.75rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		margin-bottom: 0.25rem;
	}
	.country-header h1 {
		margin-bottom: 1.5rem;
	}
	.flag {
		font-family: var(--f-body);
		font-style: normal;
	}

	.stats-row {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem 2.5rem;
	}
	.stat {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}
	.stat-value {
		font-size: 2.25rem;
		font-weight: 500;
		line-height: 1;
	}
	.years-value {
		font-size: 1rem;
		line-height: 1.125;
	}
	.stat-label {
		font-size: 0.75rem;
	}
	.broadcaster-logos {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		gap: 1rem;
		align-items: center;
	}
	.broadcaster-logo {
		display: block;
		margin: 0.25rem 0;
		height: 1.75rem;
		width: auto;
		max-width: 10rem;
	}
	.broadcaster-logo--square {
		height: 3.5rem;
	}

	/* ── History section ────────────────────────────────────────── */
	.history-section h2 {
		font-family: var(--f-mono);
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--c-muted);
		font-weight: 400;
		margin-bottom: 1rem;
	}
	.history-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}
	.history-table th {
		font-family: var(--f-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--c-muted);
		font-weight: 400;
		padding: 0.6rem 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--c-border);
	}
	.history-table th.right {
		text-align: right;
	}
	.history-table td {
		padding: 0.6rem 0.75rem;
		border-bottom: 1px solid
			color-mix(in srgb, var(--c-border) 50%, transparent);
		vertical-align: middle;
	}
	.history-table tr:hover td {
		background: var(--c-surface);
	}
	.history-table .right {
		text-align: right;
	}

	.row--winner td {
		background: var(--c-surface-gold);
	}
	.row--winner:hover td {
		background: var(--c-surface-gold-hover);
	}

	.year-link {
		color: var(--c-link);
		font-weight: 500;
	}
	.song-cell a {
		color: var(--c-muted);
	}
	.song-cell a:hover {
		color: var(--c-link);
	}
	/* ── Sortable headers ─────────────────────────────────── */
	.history-table th[data-sort] {
		cursor: pointer;
		user-select: none;
		white-space: nowrap;
	}
	.history-table th[data-sort]:hover {
		color: var(--c-text);
	}
	.history-table th.th-sorted {
		color: var(--c-gold);
	}
	.history-table th.th-sorted::after {
		content: " ↑";
	}
	.history-table th.th-sorted.th-sorted-desc::after {
		content: " ↓";
	}
</style>

<script>
	const tableEl = document.querySelector(
		".history-table",
	) as HTMLTableElement | null;
	if (tableEl) {
		const table = tableEl; // stable non-null ref for inner function closures
		const tbody = table.querySelector("tbody") as HTMLTableSectionElement;
		let col = "year",
			dir = "desc";
		const numCols = new Set(["year", "place", "points"]);
		const defaults: Record<string, string> = {
			year: "desc",
			artist: "asc",
			song: "asc",
			place: "asc",
			points: "desc",
		};

		// Empty string (null values) always sort last regardless of direction
		function numVal(v: string): number {
			return v === "" ? Infinity : Number(v);
		}

		function refresh() {
			table.querySelectorAll("th[data-sort]").forEach((el) => {
				const th = el as HTMLElement;
				const key = th.dataset.sort;
				th.classList.toggle("th-sorted", key === col);
				th.classList.toggle("th-sorted-desc", key === col && dir === "desc");
			});
		}

		function sort() {
			const rows = [...tbody.querySelectorAll("tr")] as HTMLElement[];
			rows.sort((a, b) => {
				const av = a.dataset[col] ?? "";
				const bv = b.dataset[col] ?? "";
				if (numCols.has(col)) {
					const na = numVal(av),
						nb = numVal(bv);
					// Infinity (null) always last, regardless of direction
					if (na === Infinity && nb === Infinity) return 0;
					if (na === Infinity) return 1;
					if (nb === Infinity) return -1;
					return dir === "asc" ? na - nb : nb - na;
				}
				return dir === "asc" ? av.localeCompare(bv) : bv.localeCompare(av);
			});
			rows.forEach((r) => tbody.appendChild(r));
			refresh();
		}

		table.querySelectorAll("th[data-sort]").forEach((el) =>
			el.addEventListener("click", () => {
				const next = (el as HTMLElement).dataset.sort ?? "";
				if (col === next) dir = dir === "asc" ? "desc" : "asc";
				else {
					col = next;
					dir = defaults[next] ?? "asc";
				}
				sort();
			}),
		);

		refresh(); // show initial indicator without re-sorting
	}
</script>
