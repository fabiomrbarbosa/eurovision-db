---
// src/pages/country/[code].astro
import Base from '../../layouts/Base.astro';
import { getCountries, getCountryHistory, getContestIndex } from '../../lib/data.ts';
import { countryFlag, ordinal } from '../../lib/utils.ts';

export async function getStaticPaths() {
  const index = getContestIndex();
  const codes = new Set<string>();
  for (const e of index) {
    for (const c of e.contestants) codes.add(c.country);
  }
  return Array.from(codes).map(code => ({ params: { code } }));
}

const { code } = Astro.params;
const countries = getCountries();
const countryName = countries[code] ?? code;
const history = getCountryHistory(code);

const wins = history.filter(h => h.finalPlace === 1).length;
const appearances = history.length;
const bestPlace = Math.min(...history.map(h => h.finalPlace ?? Infinity));
---

<Base
  title={countryName}
  description={`${countryName} at the Eurovision Song Contest — ${appearances} appearances, ${wins} wins.`}
>
  <div class="container">

    <header class="country-header">
      <p class="eyebrow mono gold">{code}</p>
      <h1><span class="flag">{countryFlag(code)}</span>{countryName}</h1>
      <div class="stats-row">
        <div class="stat">
          <span class="stat-value mono gold">{wins}</span>
          <span class="stat-label muted">Win{wins !== 1 ? 's' : ''}</span>
        </div>
        <div class="stat">
          <span class="stat-value mono">{appearances}</span>
          <span class="stat-label muted">Appearances</span>
        </div>
        {bestPlace !== Infinity && (
          <div class="stat">
            <span class="stat-value mono">{bestPlace}</span>
            <span class="stat-label muted">Best place</span>
          </div>
        )}
        {history.length > 0 && (
          <div class="stat">
            <span class="stat-value mono">{history[0].year}–{history[history.length - 1].year}</span>
            <span class="stat-label muted">Active years</span>
          </div>
        )}
      </div>
    </header>

    <section class="history-section">
      <h2>Contest history</h2>
      <table class="history-table">
        <thead>
          <tr>
            <th>Year</th>
            <th>Artist</th>
            <th>Song</th>
            <th class="right">Final</th>
            <th class="right">Points</th>
          </tr>
        </thead>
        <tbody>
          {history.slice().reverse().map(h => (
            <tr class:list={[h.finalPlace === 1 && 'row--winner']}>
              <td>
                <a href={`/contest/${h.year}`} class="year-link mono">
                  {h.year}
                </a>
              </td>
              <td>{h.artist}</td>
              <td class="song-cell"><em>{h.song}</em></td>
              <td class="right mono">
                {h.finalPlace === 1
                  ? <span class="gold">🏆 1st</span>
                  : h.finalPlace !== null
                    ? <span class="muted">{h.finalPlace}{ordinal(h.finalPlace)}</span>
                    : h.cancelled
                      ? <span class="badge--cancelled">Cancelled</span>
                      : <span class="muted">DNQ</span>
                }
              </td>
              <td class="right mono">
                {h.finalPoints !== null
                  ? <span class:list={[h.finalPlace === 1 && 'gold']}>{h.finalPoints}</span>
                  : <span class="muted">—</span>
                }
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

  </div>
</Base>


<style>
  /* ── Country header ─────────────────────────────────────────── */
  .country-header {
    padding-block: 3rem 2.5rem;
    border-bottom: 1px solid var(--c-border);
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }
  .country-header h1 { font-size: clamp(2.5rem, 6vw, 4rem); margin-bottom: 1.5rem; }
  .flag { font-family: var(--f-body); font-style: normal; margin-right: 0.3em; }

  .stats-row {
    display: flex;
    flex-wrap: wrap;
    gap: 2.5rem;
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .stat-value { font-size: 2rem; font-weight: 500; line-height: 1; }
  .stat-label { font-size: 0.75rem; }

  /* ── History section ────────────────────────────────────────── */
  .history-section h2 {
    font-family: var(--f-mono);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--c-muted);
    font-weight: 400;
    margin-bottom: 1rem;
  }
  .history-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .history-table th {
    font-family: var(--f-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-muted);
    font-weight: 400;
    padding: 0.6rem 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--c-border);
  }
  .history-table th.right { text-align: right; }
  .history-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid color-mix(in srgb, var(--c-border) 50%, transparent);
    vertical-align: middle;
  }
  .history-table tr:hover td { background: var(--c-surface); }
  .history-table .right { text-align: right; }

  .row--winner td { background: #1a1608; }
  .row--winner:hover td { background: #201c0a; }

  .year-link { color: var(--c-gold); font-weight: 500; }
  .song-cell em { color: var(--c-muted); }
  .badge--cancelled {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-muted);
    border: 1px solid var(--c-border);
    border-radius: 3px;
    padding: 0.1em 0.4em;
  }
</style>
