{
  "name": "eurovision-app",
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "fetch:data": "npx tsx scripts/fetch-all.ts",
    "fetch:data:junior": "npx tsx scripts/fetch-all.ts --type junior",
    "fetch:data:contestants": "npx tsx scripts/fetch-all.ts --contestants",
    "fetch:year": "npx tsx scripts/fetch-all.ts --year",
    "sync:data": "rm -rf public/data && ln -s ../src/data public/data"
  },
  "dependencies": {
    "@astrojs/svelte": "^8.1.1",
    "astro": "^6.3.7",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
